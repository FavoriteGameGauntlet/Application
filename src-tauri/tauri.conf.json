{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "FavoriteGameGauntlet",
	"version": "0.1.1",
	"identifier": "com.fgg-challenge.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Favorite Game Gauntlet",
				"width": 800,
				"height": 600,
				"minWidth": 800,
				"minHeight": 600,
				"center": true
			}
		],
		"security": {
			"csp": "default-src 'self'; connect-src 'self' https://api.fgg-challenge.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; font-src 'self' data:"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2Mjg2NkJCODlFMkI4QTUKUldTbHVPS0p1MllvbHZGTW44OW5JTmZZaVpmcy9mSHF4d2p5T2ZORnQ1VmZkbzlKU2F4c1ZZdFIK",
			"endpoints": [
				"https://github.com/FavoriteGameGauntlet/Application/releases/latest/download/latest.json"
			]
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "nsis",
		"windows": {
			"nsis": {
				"installMode": "both"
			}
		}
	}
}
